# ===========================================
# Jakselnews Gitignore
# ===========================================

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production - DO NOT IGNORE server/ and dist/ - needed for Docker
# /build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - CRITICAL: Never commit these
.env
.env.local
.env.production
.env.development
.env.*.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# IDE
.idea/
.vscode/
*.swp
*.swo

# Docker (keep docker files, ignore containers)
.docker/

# Nginx (local SSL certs)
nginx/ssl/*.pem
nginx/ssl/*.key

# Logs
*.log
logs/

# OS files
Thumbs.db
.DS_Store

# ===========================================
# NOTE: server/ and dist/ are NOT ignored
# They are needed for Docker image builds
# ===========================================
